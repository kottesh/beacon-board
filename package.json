{
  "name": "beacon-board",
  "version": "0.4.0",
  "description": "Tiny TypeScript status board that summarizes service health for solo projects",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && npm run build:web",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "build:web": "esbuild web/main.ts --bundle --format=esm --outfile=public/main.js"
  },
  "keywords": [
    "status",
    "healthcheck",
    "typescript",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "esbuild": "latest"
  }
}
